{$IFDEF METHODS}
function Backtrack: TIntegerArray; overload;
function Echo: TIntegerArray; overload;
function Echoed: TIntegerArray; overload;
function Infuse(var target: TIntegerArray): Integer; overload;
function Obverse: TIntegerArray; overload;
function Obvert: TIntegerArray; overload;
function Recant: TIntegerArray; overload;
function Reconstructed: TIntegerArray; overload;
function Recurse: TIntegerArray; overload;
function Recursed: TIntegerArray; overload;
function Reflection: TIntegerArray; overload;
function Regress: TIntegerArray; overload;
function Retrace: TIntegerArray; overload;
function Retraced: TIntegerArray; overload;
function Retrograde: TIntegerArray; overload;
function Rewind: TIntegerArray; overload;
function Transpose: TIntegerArray; overload;
function Versus: TIntegerArray; overload;
{$ENDIF}

{$IFDEF IMPLEMENTATION}
{==============================================================================]
  <Backtrack>
  @action: Returns a TIntegerArray containing the range elements in reverse order
           compared to the natural direction of the range, without modifying the TRange itself.
  @note: Uses direct array allocation and a simple loop to fill values in reverse.
         Fully type-safe and works for both ascending and descending ranges.
[==============================================================================}
function TRange.Backtrack: TIntegerArray; overload;
var
  i, l, s, v: Integer;
begin
  l := Self.Size;
  SetLength(Result, l);
  s := IfThen(Self.Ascending, 1, -1);
  v := (Self.start + ((l - 1) * s));
  for i := 0 to (l - 1) do
    Result[i] := v.Decrease(s);
end;

{==============================================================================]
  <Echo>
  @action: Returns an integer array representing the range enumerated in reverse order,
           starting from Stop and progressing opposite to Wind until all elements are produced.
  @note: The resulting array length equals Size. Values are generated by subtracting Wind from the previous element on each iteration.
         The range instance is not modified. This implementation appends dynamically and may incur repeated reallocations.
[==============================================================================}
function TRange.Echo: TIntegerArray; overload;
var
  s, d: Integer;
begin
  Result := [Self.stop];
  s := Self.Size;
  d := Self.Wind;
  while (s.Decrement > 0) do
    Result := (Result + [Result[High(Result)] - d]);
end;

{==============================================================================]
  <Echoed>
  @action: Materializes a reversed reflection of the range into an array.
  @note: 
    - Logic: Initializes the array with the 'stop' value as a baseline and 
      iteratively "echoes" the sequence back to the start by applying a 
      directional increment (d).
    - Semantic: Treats the 'stop' boundary as a reflective surface. If 
      'Manifest' is the original signal, 'Echoed' is its return.
    - Implementation: Leverages fluent helpers (.Create, .Increase) for 
      a highly readable, expressive construction.
[==============================================================================}
function TRange.Echoed: TIntegerArray; overload;
var
  i, r, d: Integer;
begin
  r := Self.stop;
  Result.Create(Self.Size, r);
  d := IfThen(Self.Ascending, -1, 1);
  for i := 0 to High(Result) do
    Result[i] := r.Increase(d);
end;

{==============================================================================]
  <Infuse>
  @action: Populates an existing array with the reversed range values.
  @note: Avoids allocations by using an open array parameter. The caller
         is responsible for ensuring the destination size is sufficient.
[==============================================================================}
function TRange.Infuse(var target: TIntegerArray): Integer; overload;
var
  s, i, v, d: Integer;
begin
  Result := target.Length;
  if (Result < 1) then
    Exit;
  s := Self.Size;
  v := Self.stop;
  d := -Self.Wind;
  for i := 0 to (Result - 1) do
    if (i < s) then
      target[i] := v.Increase(d)
    else
      Break;
end;

{==============================================================================]
  <Obverse>
  @action: Materializes the "other face" of the range into an array, 
           beginning from the stop boundary.
  @note: 
    - Logic: Employs a relative-offset pointer walk. The first element is 
      seeded with 'stop', and subsequent elements are derived by 
      referencing the previous memory address (P[-1]) plus the direction (d).
    - Semantic: Treats the range as a two-sided entity; this method 
      discloses the side that is usually hidden (the reverse).
    - Performance: Highly optimized for CPU caches by utilizing relative 
      pointer arithmetic and a single-pass write.
[==============================================================================}
function TRange.Obverse: TIntegerArray; overload;
var
  P: PInteger;
  i, s, d: Integer;
begin
  s := Self.Size;
  if (s = 1) then
    Exit([Self.stop]);
  SetLength(Result, s);
  P := @Result[0];
  d := IfThen(Self.Ascending, -1, 1);
  P^ := Self.stop;
  for i := 1 to (s - 1) do
  begin
    Inc(P);
    P^ := (P[-1] + d);
  end;
end;

{==============================================================================]
  <Obvert>
  @action: Uses a branchless mathematical mapping to project values.
  @note: Calculates a "Magic Sum" (Start + Stop) and subtracts the
         current forward value from it to find the reversed counterpart.
[==============================================================================}
function TRange.Obvert: TIntegerArray; overload;
var
  i, r: Integer;
begin
  SetLength(Result, Self.Size);
  r := (Self.start + Self.stop);
  for i := 0 to High(Result) do
    Result[i] := (r - (Self.start + (i * Self.Wind)));
end;

{==============================================================================]
  <Recant>
  @action: Materializes the range into an array starting from the 'stop' 
           boundary and stepping toward the 'start'.
  @note: 
    - Logic: Calculates the value for each index by applying a directional 
      offset (d) to the stop value (r). 
    - Performance: Highly optimized; uses a single-pass loop with no 
      intermediate object or array allocations.
    - Safety: Handles small ranges (size < 2) by explicitly returning 
      the stop value as a single-element array.
    - Semantic: Effectively "withdraws" the range, beginning at the end.
[==============================================================================}
function TRange.Recant: TIntegerArray; overload;
var
  i, s, r, d: Integer;
begin
  s := Self.Size;
  SetLength(Result, s);
  if (s < 2) then
    Exit([Self.stop]);
  r := Self.stop;
  d := IfThen(Self.Ascending, -1, 1);
  for i := 0 to (s - 1) do
    Result[i] := (r + (i * d));
end;

{==============================================================================]
  <Reconstructed>
  @action: Re-initializes the range parameters in reverse and materializes 
           the resulting sequence into an array.
  @note: 
    - Logic: Explicitly invokes 'TRange.Construct' using 'stop' as the new 
      origin and 'start' as the new destination, followed by '.Items'.
    - Semantic: Implies a formal "re-building" process. Unlike memory-mapped 
      swaps, this method treats the inversion as a fresh construction 
      of a new integer sequence.
    - Result: Ensures a geometrically sound reversal by re-running the 
      primary instantiation logic from the opposite pole.
[==============================================================================}
function TRange.Reconstructed: TIntegerArray; overload;
begin
  Result := TRange.Construct(Self.stop, Self.start).Items;
end;

{==============================================================================]
  <Recurse>
  @action: Recursively deconstructs the range and reassembles the elements 
           in reverse order.
  @note: 
    - Base Case: A range of size 1 returns its start value.
    - Recursive Step: Returns the 'Recurse' of the remainder of the range 
      plus the current starting element.
    - Warning: While elegant, this is O(n²) due to array concatenations 
      and can hit stack limits on very large ranges.
[==============================================================================}
function TRange.Recurse: TIntegerArray; overload;
begin
  if (Self.Size < 2) then
    Exit([Self.start]);
  Result := (TRange.Construct((Self.start + Self.Wind), Self.stop).Recurse + [Self.start]);
end;

{==============================================================================]
  <Recursed>
  @action: Materializes the range into a reversed array using a recursive 
           divide-and-conquer strategy.
  @note: 
    - Logic: Splits the range at its midpoint (P). It then recursively 
      calls 'Recursed' on the upper partition and the lower partition, 
      concatenating them in reverse order (Upper + Lower).
    - Architecture: Logarithmic recursion depth ensures better stack safety 
      than linear recursion for larger ranges.
    - Semantic: "Recursed" implies the range is folding back on itself 
      through repeated self-division until only individual atoms remain.
[==============================================================================}
function TRange.Recursed: TIntegerArray; overload;
var
  s, M, P, w: Integer;
begin
  s := Self.Size;
  if (s < 2) then
    Exit([Self.start]);
  M := (s div 2);
  w := Self.Wind;
  P := (Self.start + (M * w));
  Result := (TRange.Construct(P, Self.stop).Recursed + TRange.Construct(Self.start, (P - w)).Recursed);
end; 

{==============================================================================]
  <Reflection>
  @action: Optimizes for small ranges by building the sequence in a
           local stack buffer.
  @note: Avoids frequent heap hits for small range operations.
[==============================================================================}
function TRange.Reflection: TIntegerArray; overload;
var
  b: array[0..63] of Integer;
  i, v, d, s: Integer;
begin
  s := Self.Size;
  if (s > 64) then
    Exit(Self.Obvert);
  v := Self.stop;
  d := -Self.Wind;
  for i := 0 to (s - 1) do
    b[i] := v.Increase(d);
  SetLength(Result, s);
  Move(b[0], Result[0], (s * SizeOf(Integer)));
end; 

{==============================================================================]
  <Regress>
  @action: Materializes the range into an array in reverse-sequential order.
  @note: 
    - Logic: Utilizes 'Self.Reversed' to flip the range boundaries and then 
      calls '.Items' (or 'Manifest') to expand the digits.
    - Semantic: From the Latin 'recantare' (to recall or revoke). It treats 
      the forward sequence as a statement that is being "walked back" 
      from 'stop' to 'start'.
    - Result: If the range is 0..3, Recant produces [3, 2, 1, 0].
[==============================================================================}
function TRange.Regress: TIntegerArray; overload;
begin
  Result := Self.Reversed.Items;
end;

{==============================================================================]
  <Retrace>
  @action: Materializes the range as a forward array and immediately inverts 
           the element order.
  @note: 
    - Logic: Chains 'Self.Items' with an array-level '.Reversed' method. 
    - Semantic: Unlike 'Recant' (which might imply building backwards), 
      'Retrace' implies the path was first fully realized and then 
      traversed in reverse.
    - Character: This is a "Compositional" approach, relying on existing 
      array transformations rather than internal range-math.
[==============================================================================}
function TRange.Retrace: TIntegerArray; overload;
begin
  Result := Self.Items.Reversed;
end;

{==============================================================================]
  <Retraced>
  @action: Materializes the range into an array by walking backward from 
           the 'stop' boundary to the 'start'.
  @note: 
    - Logic: Employs a high-speed pointer-walk. It initializes at the 
      'stop' value and increments a memory pointer (P) while adjusting 
      the value (r) by a calculated direction (d).
    - Performance: Extremely efficient; bypasses standard array indexing 
      for direct memory injection.
    - Semantic: Implies a journey back to the origin. If the range is the 
      path taken, 'Retraced' is the act of walking it in reverse.
    - Result: A single-pass, O(n) materialization with minimal CPU cycles.
[==============================================================================}
function TRange.Retraced: TIntegerArray; overload;
var
  P: PInteger;
  r, d, i, s: Integer;
begin
  s := Self.Size;
  if (s = 1) then
    Exit([Self.stop]);
  SetLength(Result, s);
  P := @Result[0];
  r := Self.stop;
  d := IfThen(Self.Ascending, -1, 1);
  for i := 0 to (s - 1) do
  begin
    P^ := r;
    Inc(P);
    Inc(r, d);
  end;
end;

{==============================================================================]
  <Retrograde>
  @action: Returns the full range of integers in reverse order relative to the
            range direction, producing a TIntegerArray.
  @note: For ascending ranges, this generates numbers from Stop down to Start.
         For descending ranges, this generates numbers from Stop up to Start.
         If the range is singular (Size = 1), the array contains only Self.Start.
         The resulting array length equals Self.Size.
[==============================================================================}
function TRange.Retrograde: TIntegerArray; overload;
var
  i, s: Integer;
begin
  s := Self.Size;
  if (s = 1) then
    Exit([Self.start]);
  SetLength(Result, s);
  case Self.Ascending of
    True:
    for i := 0 to (s - 1) do
      Result[i] := (((Self.start + s) - 1) - i);
    False:
    for i := 0 to (s - 1) do
      Result[i] := (((Self.start - s) + 1) + i);
  end;
end;

{==============================================================================]
  <Rewind>
  @action: Returns a TIntegerArray containing all values of the range
           in **reverse order** relative to the range direction.
  @note:
    - Works for ascending or descending ranges.
    - If the range is singular (Size = 1), the array contains only Self.Start.
    - The array length equals Self.Size.
[==============================================================================}
function TRange.Rewind: TIntegerArray; overload;
var
  i, s: Integer;
begin
  s := Self.Size;
  if (s = 1) then
    Exit([Self.start]);
  SetLength(Result, s);
  for i := 0 to (s - 1) do
    if Self.Ascending then
      Result[i] := (Self.stop - i)
    else
      Result[i] := (Self.stop + i);
end;

{==============================================================================]
  <Transpose>
  @action: Populates the array from both poles simultaneously.
  @note: Uses a symmetric approach where the start and stop are processed
         in tandem, meeting at the range's midpoint.
[==============================================================================}
function TRange.Transpose: TIntegerArray; overload;
var
  i, j, d, s: Integer;
  r: TRange;
begin
  s := Self.Size;
  if (s = 1) then
    Exit([Self.stop]);
  SetLength(Result, s);
  r.start := Self.start;
  r.stop := Self.stop;
  d := Self.Wind;
  j := (s - 1);
  for i := 0 to (s div 2) do
  begin
    Result[j - i] := r.start.Increase(d);
    Result[i] := r.stop.Decrease(d);
  end;
end;

{==============================================================================]
  <Versus>
  @action: Materializes the reverse range using index-inversion math.
  @note: Uses the property: ValueAt(i) = Stop - (i * Wind).
         This is the most stable "O(n)" approach for FPC's optimizer.
[==============================================================================}
function TRange.Versus: TIntegerArray; overload;
var
  i, s, w: Integer;
begin
  SetLength(Result, Self.Size);
  w := Self.Wind;
  s := Self.stop;
  for i := 0 to High(Result) do
    Result[i] := (s - (i * w));
end;
{$ENDIF}
